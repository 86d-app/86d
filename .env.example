# ============================================================================
# 86d Store — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the required values.
# ============================================================================

# ── Required ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/86d"
DATABASE_URL_UNPOOLED="postgresql://postgres:postgres@localhost:5432/86d"

# Auth secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-to-a-random-string"

# Store identifier — get this from `bun run db:seed` output
# When set (valid UUID), store config is fetched from the 86d API instead of template/config.json
# STORE_ID=""

# Admin credentials used by `bun run db:seed` and `docker compose up`
# Defaults: admin@example.com / password123
# ADMIN_EMAIL=""
# ADMIN_PASSWORD=""

# 86d API (optional — when STORE_ID is set, fetch store config from hosted API)
# 86D_API_URL="https://api.86d.app"
# 86D_API_KEY=""

# ── Defaults (optional to override) ─────────────────────────────────────────

# APP_URL="http://localhost:3000"
# BETTER_AUTH_URL="http://localhost:3000"
# NODE_ENV="development"

# ── Email (Resend) ──────────────────────────────────────────────────────────

# RESEND_API_KEY=""

# ── Auth Providers (all optional) ────────────────────────────────────────────

# Google
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
# NEXT_PUBLIC_AUTH_GOOGLE_ID=""

# Twitter / X
# AUTH_TWITTER_ID=""
# AUTH_TWITTER_SECRET=""

# Slack
# AUTH_SLACK_ID=""
# AUTH_SLACK_SECRET=""

# Shopify
# AUTH_SHOPIFY_ID=""
# AUTH_SHOPIFY_SECRET=""

# Apple
# AUTH_APPLE_ID=""
# AUTH_APPLE_SECRET=""
# AUTH_APPLE_BUNDLE_IDENTIFIER=""

# Facebook
# AUTH_FACEBOOK_ID=""
# AUTH_FACEBOOK_SECRET=""

# ── Payment Providers ────────────────────────────────────────────────────────
# The first configured provider is automatically wired to the payments module.
# Priority: Stripe > PayPal > Square > Braintree

# Stripe
# STRIPE_ACCOUNT_ID=""
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# PayPal
# PAYPAL_CLIENT_ID=""
# PAYPAL_CLIENT_SECRET=""
# PAYPAL_SANDBOX="true"
# PAYPAL_WEBHOOK_ID=""

# Square
# SQUARE_ACCESS_TOKEN=""
# NEXT_PUBLIC_SQUARE_APPLICATION_ID=""
# NEXT_PUBLIC_SQUARE_LOCATION_ID=""
# SQUARE_WEBHOOK_SIGNATURE_KEY=""
# SQUARE_WEBHOOK_NOTIFICATION_URL=""

# Braintree
# BRAINTREE_MERCHANT_ID=""
# BRAINTREE_PUBLIC_KEY=""
# BRAINTREE_PRIVATE_KEY=""
# BRAINTREE_SANDBOX="true"

# ── Storage ─────────────────────────────────────────────────────────────────

# Storage provider: "local" (default), "vercel", or "s3"
# STORAGE_PROVIDER="local"

# Public URL mode: "direct" (default) or "proxy"
# Use "proxy" in Docker MinIO setups to serve uploads from /uploads/... instead of raw bucket URLs.
# STORAGE_PUBLIC_URL_MODE="direct"

# Local storage (default in bare local dev)
# STORAGE_LOCAL_DIR="./uploads"
# STORAGE_LOCAL_BASE_URL="/uploads"

# Vercel Blob (when deploying to Vercel)
# VERCEL_BLOB_STORAGE_HOSTNAME=""
# BLOB_READ_WRITE_TOKEN=""

# S3-compatible (MinIO, AWS S3, Cloudflare R2, Railway Bucket)
# S3_ENDPOINT=""
# S3_BUCKET=""
# S3_REGION="us-east-1"
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
# Railway Bucket uses virtual-hosted URLs — set when using Railway object storage:
# S3_VIRTUAL_HOSTED_STYLE="true"

# Docker Compose MinIO defaults
# MINIO_ROOT_USER="minioadmin"
# MINIO_ROOT_PASSWORD="minioadmin"
# MINIO_API_PUBLISH_PORT="9000"
# MINIO_CONSOLE_PUBLISH_PORT="9001"

# ── Railway (hosted deploy — e.g. https://railway.com/deploy/WKYLrk) ───────

# Populated by Railway at runtime (hostname only — use https:// in APP_URL / NEXT_PUBLIC_STORE_URL)
# RAILWAY_PUBLIC_DOMAIN=""
# RAILWAY_PROJECT_ID=""
# RAILWAY_SERVICE_ID=""
# RAILWAY_ENVIRONMENT_ID=""

# ── SMS (Twilio) ─────────────────────────────────────────────────────────────

# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_SERVICE_SID=""
# TWILIO_PHONE_NUMBER="+18448710434"

# ── AI / LLM ─────────────────────────────────────────────────────────────────

# OPENAI_API_KEY=""
# GEMINI_API_KEY=""
# OPENROUTER_API_KEY=""

# ── Maps ─────────────────────────────────────────────────────────────────────

# GOOGLE_MAPS_API_KEY=""

# ── Toast POS ────────────────────────────────────────────────────────────────

# TOAST_API_KEY=""
# TOAST_RESTAURANT_GUID=""
# TOAST_SANDBOX="true"

# ── Analytics & Monitoring ───────────────────────────────────────────────────

# NEXT_PUBLIC_GOOGLE_TAG_MANAGER_ID=""
# SENTRY_DSN=""
