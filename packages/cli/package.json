{
	"name": "86d",
	"version": "0.0.3",
	"description": "CLI for 86d — modular, open-source commerce platform",
	"type": "module",
	"license": "MIT",
	"author": "86d <chat@86d.app>",
	"repository": {
		"type": "git",
		"url": "https://github.com/86d-app/86d.git",
		"directory": "packages/cli"
	},
	"homepage": "https://github.com/86d-app/86d/tree/main/packages/cli",
	"bin": {
		"86d": "./src/index.ts"
	},
	"files": [
		"src"
	],
	"keywords": [
		"86d",
		"commerce",
		"ecommerce",
		"modular",
		"cli"
	],
	"scripts": {
		"dev": "tsx src/index.ts",
		"build": "tsc",
		"check": "biome check src",
		"check:fix": "biome check --write src",
		"test": "vitest run",
		"typecheck": "tsc --noEmit --emitDeclarationOnly false"
	},
	"dependencies": {
		"@86d-app/core": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@types/node": "catalog:node",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:vite"
	}
}