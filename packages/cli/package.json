{
	"name": "@86d-app/86d",
	"version": "0.0.1",
	"description": "CLI for 86d — modular, open-source commerce platform",
	"type": "module",
	"license": "MIT",
	"bin": {
		"86d": "./src/index.ts"
	},
	"files": [
		"src"
	],
	"keywords": [
		"86d",
		"commerce",
		"ecommerce",
		"modular",
		"cli"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/86d-app/86d",
		"directory": "packages/cli"
	},
	"scripts": {
		"dev": "tsx src/index.ts",
		"build": "tsc",
		"check": "biome check src",
		"check:fix": "biome check --write src",
		"typecheck": "tsc --noEmit --emitDeclarationOnly false"
	},
	"dependencies": {
		"@86d-app/core": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@types/node": "catalog:node",
		"tsx": "catalog:",
		"typescript": "catalog:"
	}
}
