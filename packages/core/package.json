{
	"name": "@86d-app/core",
	"version": "0.0.4",
	"description": "Core package for 86d dynamic commerce platform",
	"type": "module",
	"license": "MIT",
	"author": "86d <chat@86d.app>",
	"repository": {
		"type": "git",
		"url": "https://github.com/86d-app/86d.git",
		"directory": "packages/core"
	},
	"homepage": "https://86d.app",
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./client": {
			"types": "./src/client/index.ts",
			"default": "./src/client/index.ts"
		},
		"./state": {
			"types": "./src/state.ts",
			"default": "./src/state.ts"
		},
		"./test-utils": {
			"types": "./src/test-utils.ts",
			"default": "./src/test-utils.ts"
		},
		"./charts": {
			"types": "./src/charts.ts",
			"default": "./src/charts.ts"
		},
		"./prisma": {
			"types": "./src/prisma/client.ts",
			"default": "./src/prisma/client.ts"
		}
	},
	"scripts": {
		"build": "tsc",
		"check": "biome check src",
		"check:fix": "biome check --write src",
		"clean": "git clean -xdf .cache .turbo dist node_modules",
		"dev": "tsc",
		"postinstall": "prisma generate",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"typecheck": "tsc --noEmit --emitDeclarationOnly false"
	},
	"dependencies": {
		"@tanstack/react-query": "catalog:trpc",
		"better-call": "1.1.8",
		"recharts": "2.15.4",
		"mobx": "6.13.7",
		"mobx-react-lite": "4.1.0",
		"superjson": "2.2.6",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@prisma/client": "catalog:prisma",
		"@standard-schema/spec": "1.1.0",
		"@types/react": "catalog:react",
		"prisma": "catalog:prisma",
		"react": "catalog:react",
		"type-fest": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:vite"
	},
	"peerDependencies": {
		"react": ">=18"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		}
	}
}