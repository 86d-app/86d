datasource db {
  provider = "postgresql"
}

generator client {
  provider               = "prisma-client"
  output                 = "../src/prisma"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
  previewFeatures        = []
}

model Module {
  id   String @id @unique @default(uuid()) @db.Uuid
  cuid String @unique @default(cuid(2)) @db.VarChar(30)

  name      String
  version   String
  isEnabled Boolean @default(true)
  settings  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  data    ModuleData[]
  store   Json?
  storeId String?      @db.Uuid

  @@index([storeId, isEnabled])
  @@map("Module")
}

model ModuleData {
  id   String @id @unique @default(uuid()) @db.Uuid
  cuid String @unique @default(cuid(2)) @db.VarChar(30)

  entityType String @db.VarChar(100)
  entityId   String @db.VarChar(255)
  data       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  moduleId String       @db.Uuid
  module   Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  children ModuleData[] @relation("ModuleDataParent")
  parentId String?      @db.Uuid
  parent   ModuleData?  @relation("ModuleDataParent", fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([moduleId, entityType, entityId], name: "module_entity_unique")
  @@index([moduleId, entityType])
  @@index([moduleId, parentId])
  @@index([entityType, entityId])
  @@map("ModuleData")
}
