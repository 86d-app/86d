datasource db {
  provider = "postgresql"
}

generator client {
  provider               = "prisma-client"
  output                 = "../src/prisma"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
  previewFeatures        = []
}

model Store {
  id                   String   @id @default(uuid())
  slugId               String   @unique @default(cuid())
  cuid                 String   @unique @default(cuid())
  name                 String
  notificationSettings Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  modules Module[]
  admins  StoreAdmin[]
}

model StoreAdmin {
  id      String @id @default(cuid())
  userId  String
  storeId String
  role    String @default("admin")

  store Store @relation(fields: [storeId], references: [id])

  @@unique([userId, storeId], name: "userId_storeId")
  @@index([userId])
  @@index([storeId])
}

model Module {
  id       String  @id @default(cuid())
  name     String
  version  String
  storeId  String
  settings Json?

  store Store @relation(fields: [storeId], references: [id])

  @@unique([storeId, name], name: "storeId_name")
  @@index([storeId])
}

model ApiKey {
  id         String    @id @default(cuid())
  keyHash    String    @unique
  storeId    String
  scopes     String[]
  revokedAt  DateTime?
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([storeId])
}

model ModuleData {
  id         String   @id @default(cuid())
  moduleId   String
  entityType String
  entityId   String
  data       Json
  parentId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  parent   ModuleData?  @relation("ModuleDataParent", fields: [parentId], references: [id])
  children ModuleData[] @relation("ModuleDataParent")

  @@unique([moduleId, entityType, entityId], name: "module_entity_unique")
  @@index([moduleId, entityType])
  @@index([parentId])
}
