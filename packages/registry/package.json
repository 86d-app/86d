{
	"name": "@86d-app/registry",
	"version": "0.0.11",
	"description": "Module registry for 86d — resolve, fetch, and cache modules from local, GitHub, or npm sources",
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"scripts": {
		"build": "tsc",
		"check": "biome check src",
		"check:fix": "biome check --write src",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"typecheck": "tsc --noEmit --emitDeclarationOnly false"
	},
	"dependencies": {
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@types/node": "catalog:node",
		"typescript": "catalog:",
		"vitest": "catalog:vite"
	}
}
