{
	"name": "ui",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./core/sonner": {
			"types": "./src/core/sonner.ts",
			"default": "./src/core/sonner.ts"
		},
		"./core/icon": {
			"types": "./src/core/icon.tsx",
			"default": "./src/core/icon.tsx"
		},
		"./core/command": {
			"types": "./src/core/command.tsx",
			"default": "./src/core/command.tsx"
		},
		"./core/input-group": {
			"types": "./src/core/input-group.tsx",
			"default": "./src/core/input-group.tsx"
		},
		"./core/kbd": {
			"types": "./src/core/kbd.tsx",
			"default": "./src/core/kbd.tsx"
		},
		"./core/spinner": {
			"types": "./src/core/spinner.tsx",
			"default": "./src/core/spinner.tsx"
		},
		"./core/view": {
			"types": "./src/core/view.tsx",
			"default": "./src/core/view.tsx"
		},
		"./auth/signin-form": {
			"types": "./src/auth/signin-form.tsx",
			"default": "./src/auth/signin-form.tsx"
		},
		"./auth/signup-form": {
			"types": "./src/auth/signup-form.tsx",
			"default": "./src/auth/signup-form.tsx"
		},
		"./auth/reset-password-form": {
			"types": "./src/auth/reset-password-form.tsx",
			"default": "./src/auth/reset-password-form.tsx"
		}
