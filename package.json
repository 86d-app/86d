{
	"name": "@86d-app/86d",
	"version": "0.0.4",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "turbo run build",
		"build:apps": "turbo run build --filter=./apps/*",
		"build:packages": "turbo run build --filter=./packages/*",
		"build:store": "turbo run build --filter=./apps/store",
		"typecheck": "turbo run typecheck",
		"check": "turbo run check",
		"check:fix": "turbo run check:fix",
		"clean": "turbo run clean && git clean -xdf .turbo .next node_modules coverage logs playwright-report",
		"dev": "dotenv -- turbo run dev --filter=store",
		"dev:store": "dotenv -- turbo run dev --filter=store",
		"start": "turbo run start",
		"test": "turbo run test",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:store": "playwright test --project=store-chromium",
		"test:e2e:ui": "playwright test --ui",
		"generate:modules": "tsx scripts/generate-modules.ts",
		"generate:registry": "tsx scripts/generate-registry.ts",
		"generate:docs": "tsx scripts/generate-component-docs.ts",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "turbo run build --filter=./packages/* --filter=./modules/* && changeset publish",
		"86d": "tsx packages/cli/src/index.ts",
		"db:seed": "dotenv -- tsx scripts/seed.ts"
	},
	"dependencies": {
		"tsx": "catalog:"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.1",
		"@biomejs/biome": "catalog:",
		"@changesets/changelog-github": "^0.6.0",
		"@changesets/cli": "^2.30.0",
		"@playwright/test": "^1.58.2",
		"@tsconfig/node-ts": "catalog:",
		"@tsconfig/node24": "catalog:",
		"@tsconfig/strictest": "catalog:",
		"@types/node": "catalog:node",
		"@vitest/coverage-v8": "^4.0.0",
		"dotenv-cli": "catalog:",
		"turbo": "^2.8.14",
		"type-fest": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:vite"
	},
	"engines": {
		"node": "23 || 24 || 25"
	},
	"workspaces": [
		"apps/*",
		"internals/*",
		"modules/*",
		"packages/*"
	],
	"catalog": {
		"@biomejs/biome": "2.3.11",
		"@tsconfig/node-ts": "23.6.2",
		"@tsconfig/node24": "24.0.3",
		"@tsconfig/strictest": "2.0.8",
		"dotenv-cli": "11.0.0",
		"@tailwindcss/postcss": "4.2.1",
		"postcss": "8.5.6",
		"slug": "11.0.1",
		"tailwindcss": "4.2.1",
		"tsx": "4.21.0",
		"turbo": "2.7.5",
		"type-fest": "5.3.1",
		"typescript": "5.9.3",
		"zod": "4.3.5"
	},
	"catalogs": {
		"mdx": {
			"@mdx-js/loader": "3.1.1",
			"@mdx-js/react": "3.1.1",
			"@next/mdx": "16.1.1",
			"@types/mdx": "2.0.13"
		},
		"next": {
			"@next/third-parties": "16.1.1",
			"@types/next": "9.0.0",
			"next": "16.1.1",
			"next-themes": "0.4.6"
		},
		"node": {
			"@types/node": "25.0.3"
		},
		"prisma": {
			"@prisma/client": "7.3.0",
			"prisma": "7.3.0"
		},
		"react": {
			"@types/react": "19.2.7",
			"@types/react-dom": "19.0.0",
			"react": "19.0.0",
			"react-dom": "19.0.0",
			"react-use": "17.6.0"
		},
		"trpc": {
			"@tanstack/react-query": "5.90.16"
		},
		"vercel": {
			"@vercel/analytics": "1.6.1"
		},
		"vite": {
			"vite": "7.3.1",
			"vite-tsconfig-paths": "6.0.3",
			"vitest": "4.0.16"
		}
	},
	"packageManager": "bun@1.3.6"
}