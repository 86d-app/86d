{
	"name": "@86d-app/backorders",
	"version": "0.0.1",
	"description": "Backorder management module for 86d commerce platform",
	"keywords": ["commerce", "backorders", "out-of-stock", "inventory", "86d"],
	"license": "MIT",
	"author": "86d <chat@86d.app>",
	"repository": {
		"type": "git",
		"url": "https://github.com/86d-app/86d.git",
		"directory": "modules/backorders"
	},
	"homepage": "https://86d.app",
	"type": "module",
	"exports": {
		"./*": "./src/*"
	},
	"scripts": {
		"build": "tsc",
		"check": "biome check src",
		"check:fix": "biome check --write src",
		"clean": "git clean -xdf .cache .turbo dist node_modules",
		"dev": "tsc",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"typecheck": "tsc --noEmit --emitDeclarationOnly false"
	},
	"dependencies": {
		"@86d-app/core": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:vite"
	}
}
