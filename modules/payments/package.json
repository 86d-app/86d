{
	"name": "@86d-app/payments",
	"version": "0.0.11",
	"description": "Payment processing abstraction for 86d commerce platform",
	"keywords": [
		"commerce",
		"payments",
		"payment-intents",
		"refunds",
		"86d"
	],
	"license": "MIT",
	"author": "86d <chat@86d.app>",
	"repository": {
		"type": "git",
		"url": "https://github.com/86d-app/86d.git",
		"directory": "modules/payments"
	},
	"homepage": "https://86d.app",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./admin-components": "./src/admin/components",
		"./*": "./src/*"
	},
	"scripts": {
		"build": "tsc",
		"check": "biome check src",
		"check:fix": "biome check --write src",
		"clean": "git clean -xdf .cache .turbo dist node_modules",
		"dev": "tsc",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"typecheck": "tsc --noEmit --emitDeclarationOnly false"
	},
	"dependencies": {
		"@86d-app/core": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@types/react": "catalog:react",
		"typescript": "catalog:",
		"vitest": "catalog:vite"
	}
}
