{
	"name": "@86d-app/google-shopping",
	"version": "0.0.12",
	"description": "Google Shopping / Merchant Center integration for 86d commerce platform",
	"keywords": [
		"commerce",
		"marketplace",
		"google-shopping",
		"86d"
	],
	"license": "MIT",
	"author": "86d <chat@86d.app>",
	"repository": {
		"type": "git",
		"url": "https://github.com/86d-app/86d.git",
		"directory": "modules/google-shopping"
	},
	"homepage": "https://86d.app",
	"type": "module",
	"exports": {
		"./components": "./src/store/components",
		"./admin-components": "./src/admin/components",
		"./*": "./src/*"
	},
	"scripts": {
		"build": "tsc",
		"check": "biome check src",
		"check:fix": "biome check --write src",
