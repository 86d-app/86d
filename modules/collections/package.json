{
	"name": "@86d-app/collections",
	"version": "0.0.19",
	"description": "Curated product collections for merchandising — manual and automatic groupings",
	"keywords": [
		"commerce",
		"collections",
		"merchandising",
		"product-groups",
		"curated"
	],
	"license": "MIT",
	"author": "86d <chat@86d.app>",
	"repository": {
		"type": "git",
		"url": "https://github.com/86d-app/86d.git",
		"directory": "modules/collections"
	},
	"homepage": "https://86d.app",
	"type": "module",
	"exports": {
		"./components": "./src/store/components",
		"./admin-components": "./src/admin/components",
		"./*": "./src/*"
	},
	"scripts": {
		"build": "tsc",
		"check": "biome check src",
		"check:fix": "biome check --write src",
		"clean": "git clean -xdf .cache .turbo dist node_modules",
		"dev": "tsc",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"typecheck": "tsc --noEmit --emitDeclarationOnly false"
	},
	"dependencies": {
		"@86d-app/core": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@types/mdx": "catalog:mdx",
		"@types/react": "catalog:react",
		"typescript": "catalog:",
		"vitest": "catalog:vite"
	}
}
